<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>SPC Diario - I-MR</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
  font-family: Arial;
  background: #0f172a;
  color: #e5e7eb;
  margin: 0;
}

.header {
  padding: 15px;
  background: #020617;
  border-bottom: 2px solid #38bdf8;
}

.controls {
  padding: 10px;
  background: #111827;
}

select, button {
  padding: 6px;
  background: #020617;
  color: #e5e7eb;
  border: 1px solid #38bdf8;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 50vh 50vh;
  gap: 10px;
  padding: 10px;
}

.card {
  background: #020617;
  border: 1px solid #38bdf8;
  border-radius: 10px;
  padding: 10px;
  display: flex;
  flex-direction: column;
}

canvas {
  flex: 1;
}

.table-container {
  overflow: auto;
  flex: 1;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

th, td {
  border: 1px solid #374151;
  padding: 4px;
  text-align: center;
}
</style>
</head>

<body>

<div class="controls">
  <label>Parte:</label>
  <select id="numeroParte">
    <% partes.forEach(p => { %>
      <option value="<%= p %>"><%= p %></option>
    <% }) %>
  </select>

  <label>Característica:</label>
  <select id="caracteristica">
    <option value="peso">Peso</option>
    <option value="r_pequena">r_pequena</option>

    <% for(let i=1;i<=10;i++){ %>
      <option value="p<%=i%>.peak">p<%=i%>.peak</option>
      <option value="p<%=i%>.root">p<%=i%>.root</option>
    <% } %>

    <option value="grandeD1">grandeD1</option>
    <option value="grandeD2">grandeD2</option>
  </select>

  <button id="btnGenerar">Generar</button>
</div>

<div class="grid">

  <div class="card">
    <h3>Datos individuales</h3>
    <div class="table-container">
      <table id="tablaDatos">
        <thead>
          <tr><th>#</th><th>Valor</th></tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <h3>Histograma</h3>
    <canvas id="histogramaChart"></canvas>
  </div>

  <div class="card">
    <h3>Individual (I)</h3>
    <canvas id="iChart"></canvas>
  </div>

  <div class="card">
    <h3>Moving Range (MR)</h3>
    <canvas id="mrChart"></canvas>
  </div>

</div>

<script>
const datos = <%- JSON.stringify(datos) %>;

function getValores(d, campo){

  if(campo === "peso"){
    return (d.peso != null) ? [d.peso] : [];
  }

  let val = null;

  if(campo === "r_pequena"){
    val = d.mediciones?.r_pequena;
  }
  else if(campo === "grandeD1" || campo === "grandeD2"){
    val = d.mediciones?.[campo];
  }
  else if(campo.includes("p")){
    let [punto, tipo] = campo.split(".");
    val = d.mediciones?.puntos?.[punto]?.[tipo];
  }

  if(!val) return [];

  return [val.A, val.B, val.C].filter(v => v != null);
}

function procesar(){

  const parte = document.getElementById("numeroParte").value;
  const campo = document.getElementById("caracteristica").value;

  let filtrados = datos.filter(d => d.numeroParte === parte);

  let valores = [];

  filtrados.forEach(d=>{
    valores.push(...getValores(d, campo));
  });

  valores = valores.filter(v => !isNaN(v));

  if(valores.length < 2){
    alert("Se requieren al menos 2 datos");
    return;
  }

  // 📊 TABLA
  let tbody = document.querySelector("#tablaDatos tbody");
  tbody.innerHTML = "";
  valores.forEach((v,i)=>{
    tbody.innerHTML += `<tr><td>${i+1}</td><td>${v}</td></tr>`;
  });

  // 📉 MR
  let mr = [];
  for(let i=1;i<valores.length;i++){
    mr.push(Math.abs(valores[i] - valores[i-1]));
  }

  // 📈 CÁLCULOS SPC
  const mean = valores.reduce((a,b)=>a+b,0)/valores.length;
  const mrBar = mr.reduce((a,b)=>a+b,0)/mr.length;

  const UCL_I = mean + 2.66 * mrBar;
  const LCL_I = mean - 2.66 * mrBar;

  const UCL_MR = 3.268 * mrBar;

  // 📊 HISTOGRAMA
  let bins = 10;
  let min = Math.min(...valores);
  let max = Math.max(...valores);
  if(min === max) max = min + 1;

  let w = (max - min) / bins;
  let hist = new Array(bins).fill(0);

  valores.forEach(v=>{
    let i = Math.min(Math.floor((v-min)/w), bins-1);
    hist[i]++;
  });

  // destruir previas
  if(window.iChartObj) iChartObj.destroy();
  if(window.mrChartObj) mrChartObj.destroy();
  if(window.histChartObj) histChartObj.destroy();

  const ctx1 = document.getElementById("iChart").getContext("2d");
  const ctx2 = document.getElementById("mrChart").getContext("2d");
  const ctx3 = document.getElementById("histogramaChart").getContext("2d");

  // 📈 I CHART
  window.iChartObj = new Chart(ctx1, {
    type: 'line',
    data: {
      labels: valores.map((_,i)=>i+1),
      datasets: [
        { label: 'Valores', data: valores, borderColor:'#22c55e' },
        { label: 'Media', data: valores.map(()=>mean), borderColor:'#facc15', borderDash:[5,5] },
        { label: 'UCL', data: valores.map(()=>UCL_I), borderColor:'#ef4444' },
        { label: 'LCL', data: valores.map(()=>LCL_I), borderColor:'#ef4444' }
      ]
    },
    options: darkOptions()
  });

  // 📉 MR CHART
  window.mrChartObj = new Chart(ctx2, {
    type: 'line',
    data: {
      labels: mr.map((_,i)=>i+1),
      datasets: [
        { label: 'MR', data: mr, borderColor:'#22c55e' },
        { label: 'MR̄', data: mr.map(()=>mrBar), borderColor:'#facc15', borderDash:[5,5] },
        { label: 'UCL', data: mr.map(()=>UCL_MR), borderColor:'#ef4444' }
      ]
    },
    options: darkOptions()
  });

  // 📊 HISTOGRAMA
  window.histChartObj = new Chart(ctx3, {
    type: 'bar',
    data: {
      labels: hist.map((_,i)=>(min+i*w).toFixed(3)),
      datasets: [{
        label: 'Frecuencia',
        data: hist,
        backgroundColor:'#38bdf8'
      }]
    },
    options: darkOptions()
  });

}

function darkOptions(){
  return {
    responsive: true,
    plugins: {
      legend: {
        labels: { color: '#e5e7eb' }
      }
    },
    scales: {
      x: {
        ticks: { color: '#e5e7eb' },
        grid: { color: '#374151' }
      },
      y: {
        ticks: { color: '#e5e7eb' },
        grid: { color: '#374151' }
      }
    }
  };
}

document.addEventListener("DOMContentLoaded", () => {
  document.getElementById("btnGenerar").addEventListener("click", procesar);
});
</script>

</body>
</html>