<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>SPC Editable Completo</title>

<style>
  body {
    font-family: Arial;
    margin: 20px;
  }

  table {
    width: max-content;
    border-collapse: collapse;
    font-size: 11px;
  }

  th, td {
    border: 1px solid #ccc;
    padding: 3px;
    text-align: center;
    min-width: 60px;
  }

  th {
    background: #f2f2f2;
    position: sticky;
    top: 0;
    z-index: 2;
  }

  input {
    width: 100%;
    border: none;
    text-align: center;
    outline: none;
    font-size: 11px;
    background: transparent;
  }

  tr:hover {
    background: #f9f9f9;
  }

  .save {
    background: #28a745;
    color: white;
    border: none;
    padding: 4px 6px;
    cursor: pointer;
  }

  .section {
    background: #ddd;
    font-weight: bold;
    text-align: left;
  }

</style>
</head>

<body>

<h2>📊 SPC Editable Completo (tipo Excel)</h2>

<table>

<thead>
<tr>
  <th rowspan="2">Parte</th>
  <th rowspan="2">Peso</th>

  <th colspan="3">R PEQUEÑA</th>

  <th colspan="6">P1</th>
  <th colspan="6">P2</th>
  <th colspan="6">P3</th>

  <th colspan="3">GRANDE D1</th>
  <th colspan="3">GRANDE D2</th>

  <th rowspan="2">💾</th>
</tr>

<tr>
  <th>A</th><th>B</th><th>C</th>

  <!-- P1 -->
  <th>PA</th><th>PB</th><th>PC</th>
  <th>RA</th><th>RB</th><th>RC</th>

  <!-- P2 -->
  <th>PA</th><th>PB</th><th>PC</th>
  <th>RA</th><th>RB</th><th>RC</th>

  <!-- P3 -->
  <th>PA</th><th>PB</th><th>PC</th>
  <th>RA</th><th>RB</th><th>RC</th>

  <th>A</th><th>B</th><th>C</th>
  <th>A</th><th>B</th><th>C</th>
</tr>
</thead>

<tbody>

<% mediciones.forEach(m => { %>
<tr data-id="<%= m._id %>">

  <!-- básicos -->
  <td><input name="numeroParte" value="<%= m.numeroParte %>"></td>
  <td><input name="peso" value="<%= m.peso %>"></td>

  <!-- R PEQUEÑA -->
  <td><input name="rpeq_A" value="<%= m.mediciones?.r_pequena?.A || '' %>"></td>
  <td><input name="rpeq_B" value="<%= m.mediciones?.r_pequena?.B || '' %>"></td>
  <td><input name="rpeq_C" value="<%= m.mediciones?.r_pequena?.C || '' %>"></td>

  <!-- ===== P1 ===== -->
  <td><input name="p1_peak_A" value="<%= m.mediciones?.puntos?.p1?.peak?.A || '' %>"></td>
  <td><input name="p1_peak_B" value="<%= m.mediciones?.puntos?.p1?.peak?.B || '' %>"></td>
  <td><input name="p1_peak_C" value="<%= m.mediciones?.puntos?.p1?.peak?.C || '' %>"></td>

  <td><input name="p1_root_A" value="<%= m.mediciones?.puntos?.p1?.root?.A || '' %>"></td>
  <td><input name="p1_root_B" value="<%= m.mediciones?.puntos?.p1?.root?.B || '' %>"></td>
  <td><input name="p1_root_C" value="<%= m.mediciones?.puntos?.p1?.root?.C || '' %>"></td>

  <!-- ===== P2 ===== -->
  <td><input name="p2_peak_A" value="<%= m.mediciones?.puntos?.p2?.peak?.A || '' %>"></td>
  <td><input name="p2_peak_B" value="<%= m.mediciones?.puntos?.p2?.peak?.B || '' %>"></td>
  <td><input name="p2_peak_C" value="<%= m.mediciones?.puntos?.p2?.peak?.C || '' %>"></td>

  <td><input name="p2_root_A" value="<%= m.mediciones?.puntos?.p2?.root?.A || '' %>"></td>
  <td><input name="p2_root_B" value="<%= m.mediciones?.puntos?.p2?.root?.B || '' %>"></td>
  <td><input name="p2_root_C" value="<%= m.mediciones?.puntos?.p2?.root?.C || '' %>"></td>

  <!-- ===== P3 ===== -->
  <td><input name="p3_peak_A" value="<%= m.mediciones?.puntos?.p3?.peak?.A || '' %>"></td>
  <td><input name="p3_peak_B" value="<%= m.mediciones?.puntos?.p3?.peak?.B || '' %>"></td>
  <td><input name="p3_peak_C" value="<%= m.mediciones?.puntos?.p3?.peak?.C || '' %>"></td>

  <td><input name="p3_root_A" value="<%= m.mediciones?.puntos?.p3?.root?.A || '' %>"></td>
  <td><input name="p3_root_B" value="<%= m.mediciones?.puntos?.p3?.root?.B || '' %>"></td>
  <td><input name="p3_root_C" value="<%= m.mediciones?.puntos?.p3?.root?.C || '' %>"></td>

  <!-- GRANDE D1 -->
  <td><input name="grandeD1_A" value="<%= m.mediciones?.grandeD1?.A || '' %>"></td>
  <td><input name="grandeD1_B" value="<%= m.mediciones?.grandeD1?.B || '' %>"></td>
  <td><input name="grandeD1_C" value="<%= m.mediciones?.grandeD1?.C || '' %>"></td>

  <!-- GRANDE D2 -->
  <td><input name="grandeD2_A" value="<%= m.mediciones?.grandeD2?.A || '' %>"></td>
  <td><input name="grandeD2_B" value="<%= m.mediciones?.grandeD2?.B || '' %>"></td>
  <td><input name="grandeD2_C" value="<%= m.mediciones?.grandeD2?.C || '' %>"></td>

  <!-- guardar -->
  <td>
    <button class="save" onclick="guardar(this)">💾</button>
  </td>

</tr>
<% }) %>

</tbody>
</table>

<script>
async function guardar(btn) {

  const row = btn.closest("tr");
  const id = row.dataset.id;

  const inputs = row.querySelectorAll("input");

  let data = {};

  inputs.forEach(i => {
    data[i.name] = i.value;
  });

  const res = await fetch(`/spcs/update/${id}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(data)
  });

  const result = await res.json();

  if (result.ok) {
    alert("✔ Guardado correctamente");
  } else {
    alert("❌ Error al guardar");
  }
}
</script>

</body>
</html>